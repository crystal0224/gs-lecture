{
  "name": "gs-session",
  "version": "1.0.0",
  "description": "AI 시대, 일하는 방식의 재설계 - GS AI 조직 세션",
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "npm run build && open dist/lecture.html",
